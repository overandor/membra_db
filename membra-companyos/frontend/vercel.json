{
  "version": 2,
  "name": "membra-companyos-dashboard",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "membra-dashboard.css",
      "use": "@vercel/static"
    },
    {
      "src": "membra-dashboard.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "https://membra-companyos-api.onrender.com/v1/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
