# Overmanifold Environment Configuration
# Copy this file to .env and fill in your values
# NO PLACEHOLDERS - ALL VALUES MUST BE REAL FOR PRODUCTION

# Environment
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DB_HOST=your_database_host
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_secure_database_password
DB_SSL_MODE=require
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis Configuration
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your_redis_password
REDIS_SSL=true
REDIS_MAX_CONNECTIONS=50

# Security Configuration
SECRET_KEY=generate_with_python_secrets_token_urlsafe_32_bytes
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
PASSWORD_MIN_LENGTH=12
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ALLOWED_ORIGINS=https://your_production_domain.com
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
MAX_REQUEST_SIZE_MB=10
API_TIMEOUT_SECONDS=30
CORS_ENABLED=true

# LLM Configuration (REQUIRED for production)
LLM_PROVIDER=openai
LLM_API_KEY=your_real_openai_api_key_or_anthropic_api_key
LLM_MODEL=gpt-4
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.3

# Blockchain Configuration (REQUIRED for DeFi operations)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_real_project_id
ETHEREUM_CHAIN_ID=1
ETHEREUM_PRIVATE_KEY=your_real_ethereum_private_key_with_gas
ETHEREUM_CONFIRMATIONS_REQUIRED=12
ETHEREUM_READ_ONLY=false

SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_real_solana_private_key
SOLANA_CONFIRMATIONS_REQUIRED=32

# DeFi Configuration
UNISWAP_V2_ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
UNISWAP_V3_ROUTER_ADDRESS=0xE592427A0AEce92De3Edee1F18E0157C05861564
DEFAULT_SLIPPAGE_TOLERANCE=0.005
DEFAULT_DEADLINE_SECONDS=300

# Monitoring Configuration
MONITORING_ENABLED=true
PROMETHEUS_PORT=9090
METRICS_ENABLED=true
TRACING_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30

# Feature Flags (JSON format)
FEATURE_FLAGS={"transaction_workers": true, "repo_tokenization": true, "browser_validators": true, "real_defi": true, "real_token_deployment": true}

# External Service Configuration
GITHUB_TOKEN=your_real_github_token_with_repo_access
IPFS_GATEWAY=https://ipfs.io/ipfs/
SMS_PROVIDER_API_KEY=your_real_sms_provider_api_key
SMS_PROVIDER_SECRET=your_real_sms_provider_secret

# Security Settings
HUMAN_APPROVAL_REQUIRED=true
MAX_TRANSACTION_VALUE=unlimited
APPROVAL_GATE_ENABLED=true
AUDIT_LOGGING_ENABLED=true