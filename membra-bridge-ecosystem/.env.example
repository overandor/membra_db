# MEMBRA Bridge Ecosystem Configuration
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://membra_user:membra_password@localhost:5432/membra_bridge
REDIS_URL=redis://localhost:6379

# IPFS Configuration
IPFS_URL=http://localhost:5001
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PATH=~/.config/solana/id.json

# Oracle Configuration
ORACLE_UPDATE_INTERVAL_SECONDS=60
ORACLE_CACHE_TTL_SECONDS=300

# Phone Wallet Configuration
PHONE_WALLET_SEED=MEMBRA_BRIDGE_ECOSYSTEM_2024
DEFAULT_PREMINED_TOKENS=1000
SMS_SEND_REWARD=10
SMS_RECEIVE_REWARD=5

# LLM Configuration
OLLAMA_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama2
INFERENCE_TIMEOUT_SECONDS=120

# ZK Verification Configuration
ZK_PROOF_TIMEOUT_SECONDS=300
MINIMUM_REPUTATION_SCORE=0.3

# Liquidity Configuration
DEFAULT_FEE_RATE=0.003
MINIMUM_LIQUIDITY=1000
MAX_SLIPPAGE=0.01

# Network Configuration
NETWORK_ID=membra-mainnet
CHAIN_ID=101
GENESIS_TIMESTAMP=2024-01-01T00:00:00Z

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
DEBUG=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/membra_bridge.log

# Security Configuration
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# Monitoring Configuration
ENABLE_METRICS=True
METRICS_PORT=9090
GRAFANA_URL=http://localhost:3000
PROMETHEUS_URL=http://localhost:9090

# Deployment Configuration
DOCKER_REGISTRY=docker.io
IMAGE_TAG=latest
AUTO_DEPLOY=True
HEALTH_CHECK_INTERVAL_SECONDS=30

# Feature Flags
ENABLE_FILE_TOKENIZATION=True
ENABLE_IPFS_BACKUP=True
ENABLE_PHONE_WALLET=True
ENABLE_SMS_MINING=True
ENABLE_ORACLE_SYSTEM=True
ENABLE_KPI_TRACKING=True
ENABLE_ZK_VERIFICATION=True
ENABLE_LLM_VALIDATION=True
ENABLE_LIQUIDITY_LAYER=True
ENABLE_SELF_DEPLOYMENT=True